# the "postgres://" prefix with "postgresql+asyncpg://".
# Drop "?sslmode=require" — SSL is configured in code via connect_args.
# Example: postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/db
DATABASE_URL=

