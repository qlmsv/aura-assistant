{
  "version": 2,
  "buildCommand": "cd landing && npm install && npm run build",
  "outputDirectory": "landing/.next",
  "installCommand": "cd landing && npm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "landing/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    },
    {
      "src": "/(.*)",
      "dest": "/landing/$1"
    }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "ADMIN_CHAT_ID": "@admin_chat_id",
    "WEBHOOK_URL": "@webhook_url",
    "WEBHOOK_SECRET": "@webhook_secret",
    "DATABASE_URL": "@database_url"
  }
}
